{
  "name": "decky-cloud-reader",
  "version": "1.0.7",
  "description": "OCR and Text-to-Speech for text-heavy games using Google Cloud services",
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "lint": "eslint .",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}'",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "test": "vitest run"
  },
  "keywords": [
    "decky",
    "plugin",
    "ocr",
    "tts",
    "accessibility",
    "steam-deck"
  ],
  "author": "mshabalov",
  "license": "MIT",
  "devDependencies": {
    "@decky/rollup": "^1.0.2",
    "@rollup/plugin-replace": "^6.0.2",
    "@decky/ui": "^4.11.0",
    "@rollup/rollup-linux-x64-gnu": "^4.56.0",
    "@types/react": "19.1.1",
    "@types/react-dom": "19.1.1",
    "rollup": "^4.53.3",
    "typescript": "^5.6.2",
    "eslint": "^9.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@decky/api": "^1.1.3",
    "react-icons": "^5.3.0",
    "tslib": "^2.7.0"
  },
  "prettier": {
    "printWidth": 120,
    "singleQuote": false,
    "trailingComma": "all"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ]
    }
  }
}
